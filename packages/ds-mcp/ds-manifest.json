          "default": "false"
        },
        {
          "name": "category",
          "type": "string",
          "default": "Category"
        },
        {
          "name": "showCategory",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "title",
          "type": "string",
          "default": "Title"
        },
        {
          "name": "showTitle",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "subtitle",
          "type": "string",
          "default": "Subtitle"
        },
        {
          "name": "showSubtitle",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "leftAsset",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "rightAsset",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "leftIcon",
          "type": "ReactNode"
        },
        {
          "name": "rightIcon",
          "type": "ReactNode"
        },
        {
          "name": "leftImage",
          "type": "string"
        },
        {
          "name": "rightImage",
          "type": "string"
        },
        {
          "name": "action",
          "type": "'none' | 'button' | '2buttons' | 'link' | '2links'",
          "default": "none"
        },
        {
          "name": "slot",
          "type": "ReactNode"
        },
        {
          "name": "showSlot",
          "type": "boolean",
          "default": "true"
        },
        {
          "name": "buttonLabel",
          "type": "string",
          "default": "Button label"
        },
        {
          "name": "buttonLabel2",
          "type": "string",
          "default": "Button label"
        },
        {
          "name": "linkLabel",
          "type": "string",
          "default": "Link label"
        },
        {
          "name": "linkLabel2",
          "type": "string",
          "default": "Link label"
        },
        {
          "name": "onClick",
          "type": "() => void"
        },
        {
          "name": "width",
          "type": "number | string",
          "default": "327"
        }
      ],
      "usage": "<BaseCard showCategory={true} category=\"Plano\" showTitle={true} title=\"Sua cobertura está ativa\" action=\"link\" linkLabel=\"Ver detalhes\" width={327} />"
    },
    {
      "name": "BottomBar",
      "description": "Bottom tab navigation. Hub screens only — never on flow/detail screens.",
      "import": "import { BottomBar } from '../components/BottomBar/BottomBar'",
      "props": [
        {
          "name": "selected",
          "type": "'Alice Agora' | 'Minha saúde' | 'Rede Alice' | 'Meu plano'",
          "default": "Alice Agora"
        },
        {
          "name": "onTabSelect",
          "type": "(tab: BottomBarSelected) => void"
        },
        {
          "name": "tab1Label",
          "type": "string",
          "default": "Alice Agora"
        },
        {
          "name": "tab2Label",
          "type": "string",
          "default": "Minha saúde"
        },
        {
          "name": "tab3Label",
          "type": "string",
          "default": "Rede Alice"
        },
        {
          "name": "tab4Label",
          "type": "string",
          "default": "Meu plano"
        },
        {
          "name": "tab1Icon",
