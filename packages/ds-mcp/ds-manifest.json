        },
        {
          "name": "tab3Icon",
          "type": "string",
          "default": "localPin"
        },
        {
          "name": "tab3ActiveIcon",
          "type": "string"
        },
        {
          "name": "meuPlanoMode",
          "type": "'photo' | 'initials'",
          "default": "initials"
        },
        {
          "name": "userInitials",
          "type": "string"
        },
        {
          "name": "userImageUrl",
