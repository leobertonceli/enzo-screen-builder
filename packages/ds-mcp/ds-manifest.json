{
  "version": "1.0.0",
  "ds": "Wonderland Design System — Alice Health",
  "importBase": "All imports from '../components/<Name>/<Name>' relative to packages/ds/src/screens/",
  "tokens": {
    "colors": {
      "--color-brand": "var(--color-magenta-60)",
      "--color-brand-pressed": "var(--color-magenta-70)",
      "--color-brand-subtle": "var(--color-magenta-00)",
      "--color-content-primary": "var(--color-gray-100)",
      "--color-content-secondary": "var(--color-gray-60)",
      "--color-content-tertiary": "var(--color-gray-50)",
      "--color-surface": "var(--color-gray-white)",
      "--color-surface-subtle": "var(--color-gray-10)",
      "--color-surface-bg": "var(--color-gray-00)",
      "--color-divider": "var(--color-gray-10)",
      "--color-stroke": "var(--color-gray-20)",
      "--color-gray-white": "#FFFFFF"
    },
    "spacing": {
      "--spacing-01": "4px",
      "--spacing-02": "8px",
      "--spacing-03": "12px",
      "--spacing-04": "16px",
      "--spacing-05": "20px",
      "--spacing-06": "24px",
      "--spacing-08": "32px",
      "--spacing-10": "40px",
      "--spacing-12": "48px",
      "--spacing-16": "64px",
      "--spacing-20": "80px",
      "--spacing-24": "96px",
      "--spacing-32": "128px",
      "--spacing-40": "160px",
      "--spacing-container-icon-01": "6px",
      "--spacing-container-icon-02": "10px",
      "--spacing-container-icon-03": "14px",
      "--spacing-container-icon-04": "18px",
      "--spacing-container-icon-05": "22px",
      "--spacing-container-icon-06": "28px"
    },
    "fontSize": {
      "--font-size-xs": "12px",
      "--font-size-sm": "14px",
      "--font-size-md": "16px",
      "--font-size-lg": "20px",
      "--font-size-xl": "24px",
      "--font-size-xxl": "32px",
      "--font-size-xxxl": "48px",
      "--font-size-xxxxl": "64px"
    },
    "fontWeight": {
      "--font-weight-light": "300",
      "--font-weight-regular": "400",
      "--font-weight-medium": "500",
      "--font-weight-semibold": "600"
    },
    "fontFamily": {
      "--font-family-base": "\"Haffer\", system-ui, sans-serif",
      "--font-family-label": "\"DM Sans\", system-ui, sans-serif"
    },
    "radius": {
      "--radius-none": "0px",
      "--radius-xxs": "4px",
      "--radius-xs": "8px",
      "--radius-sm": "12px",
      "--radius-md": "16px",
      "--radius-lg": "20px",
      "--radius-xl": "24px",
      "--radius-xxl": "32px",
      "--radius-pill": "1000px"
    }
  },
  "rules": [
    "NEVER hardcode colors, spacing, font sizes — always use var(--token).",
    "NEVER recreate a component — compose from what exists.",
    "Use style={{}} for token values. Tailwind only for layout (flex, grid, overflow).",
    "fontFamily is required on every text element you write directly.",
    "Screen background is var(--color-surface).",
    "Last ListItem in a group: divider={false}.",
    "CTA Button always outside the scroll container (flex column pattern).",
    "Page titles in flow screens: <h1> with font-size-xl (24px) regular below NavBar — NOT in NavBar title prop.",
    "Icon color defaults to var(--color-content-primary). Icons use camelCase names."
  ],
  "components": [
    {
      "name": "Avatar",
      "description": "User photo or initials avatar.",
      "import": "import { Avatar } from '../components/Avatar/Avatar'",
      "props": [
        {
          "name": "size",
          "type": "'large' | 'medium' | 'small' | 'xsmall'",
          "default": "large"
        },
        {
          "name": "type",
          "type": "'image' | 'placeholder'",
          "default": "placeholder"
        },
        {
          "name": "status",
          "type": "'idle' | 'active'",
          "default": "idle"
        },
        {
          "name": "src",
          "type": "string"
        }
      ],
      "usage": "<Avatar size=\"small\" type=\"image\" status=\"idle\" src={personPhoto} />"
    },
    {
      "name": "Badge",
      "description": "Notification count badge.",
      "import": "import { Badge } from '../components/Badge/Badge'",
      "props": [
        {
          "name": "type",
          "type": "'counter' | 'dot'",
          "default": "counter"
        },
        {
          "name": "size",
          "type": "'sm' | 'md'",
          "default": "md"
        },
        {
          "name": "stroke",
          "type": "boolean",
          "default": "false"
        },
        {
          "name": "count",
          "type": "number",
          "default": "1"
        },
        {
          "name": "style",
          "type": "CSSProperties"
        }
      ],
      "usage": "<Badge count={3} />"
    },
    {
      "name": "BaseCard",
      "description": "Content card with optional category, title, subtitle, slot, and actions. Never place two side by side.",
      "import": "import { BaseCard } from '../components/BaseCard/BaseCard'",
